# Study Decoder Environment Configuration
# Copy this file to .env and fill in your values

# Server Configuration
NODE_ENV=production
PORT=3001

# Session Secret (generate a random 32+ character string)
SESSION_SECRET=your-super-secret-session-key-here

# Google OAuth (get from Google Cloud Console)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Stripe (get from Stripe Dashboard)
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Frontend URL (no trailing slash)
FRONTEND_URL=https://studydecoder.com.au

# Email Configuration (for password reset)
# To set up Gmail:
# 1. Go to Google Account > Security > 2-Step Verification (enable it)
# 2. Go to Google Account > Security > App passwords
# 3. Create a new app password for "Mail"
# 4. Copy the 16-character password (without spaces)
EMAIL_USER=your-email@gmail.com
EMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Owner Email (gets full admin access)
OWNER_EMAIL=yazhat42@gmail.com

# OG Code Configuration (optional)
OG_CODE=STDYOG
OG_MAX_REDEMPTIONS=6
